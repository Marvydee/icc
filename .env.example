# --- Database (Hostinger MySQL) ---
# Find these in hPanel > Databases > MySQL Databases
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# --- App ---
PORT=3000
APP_BASE_URL=https://yourdomain.com

# --- WhatsApp ---
# The REAL group invite link. Never expose this in any public HTML/JS.
WHATSAPP_GROUP_LINK=https://chat.whatsapp.com/REPLACE_ME

# --- Scoring ---
# Minimum score (out of 100) required to auto-pass
PASS_MARK=70

# --- Admin ---
# Simple shared password for the admin dashboard (replace with something strong)
ADMIN_PASSWORD=change_me_now

# --- Community info (used on landing page) ---
COMMUNITY_NAME=Your Community Name

# --- Social links (shown in the footer) ---
# Replace with the real Instagram link when you have one.
INSTAGRAM_URL=https://instagram.com/REPLACE_WITH_REAL_HANDLE
