<%
/*
  Shared head partial. Include from a page like this:
    include partials/head, passing pageTitle: 'Your Page Title'

  Optional overrides (defaults shown):
    pageTitle:   required, full title text for this page
    description: optional, defaults to the community's general description
                 below if omitted. Pass a page-specific one where it helps
                 (e.g. the claim page could describe what's being joined).
    canonicalPath: optional, the page's path (e.g. /apply), used to build
                 the og:url / twitter:url so link previews point at the
                 actual page being shared, not always the homepage.
                 Defaults to / if omitted.
*/
const metaDescription = typeof description !== 'undefined' && description
  ? description
  : `A vetted community for genuine connection. Apply to join ${communityName} — a short application, a few honest questions, and a private invitation if you're a fit.`;
const SITE_ORIGIN = 'https://icc.mdjforge.com';
const pagePath = typeof canonicalPath !== 'undefined' && canonicalPath ? canonicalPath : '/';
const canonicalUrl = SITE_ORIGIN + pagePath;
%>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<!-- Favicons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
<link rel="shortcut icon" href="/favicon.ico">
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
<link rel="manifest" href="/site.webmanifest">
<meta name="theme-color" content="#f1eff2">

<% if (typeof noIndex !== 'undefined' && noIndex) { %>
<meta name="robots" content="noindex, nofollow">
<% } %>

<!-- Primary meta tags -->
<title><%= pageTitle %></title>
<meta name="title" content="<%= pageTitle %>">
<meta name="description" content="<%= metaDescription %>">

<!-- Open Graph / Facebook, WhatsApp, Telegram link previews -->
<meta property="og:type" content="website">
<meta property="og:url" content="<%= canonicalUrl %>">
<meta property="og:title" content="<%= pageTitle %>">
<meta property="og:description" content="<%= metaDescription %>">
<meta property="og:image" content="<%= SITE_ORIGIN %>/og-image.png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:site_name" content="<%= communityName %>">

<!-- Twitter / X card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:url" content="<%= canonicalUrl %>">
<meta name="twitter:title" content="<%= pageTitle %>">
<meta name="twitter:description" content="<%= metaDescription %>">
<meta name="twitter:image" content="<%= SITE_ORIGIN %>/og-image.png">

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<!-- Styles -->
<link rel="stylesheet" href="/styles.css">
