<footer class="foot">
  <% if (typeof footerNote !== 'undefined' && footerNote) { %>
    <p><%= footerNote %></p>
  <% } %>

  <% if (instagramUrl || telegramUrl) { %>
    <div class="social-links">
      <% if (instagramUrl) { %>
        <a href="<%= instagramUrl %>" class="social-link" aria-label="Instagram" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="3" y="3" width="18" height="18" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none"/>
          </svg>
        </a>
      <% } %>
      <% if (telegramUrl) { %>
        <a href="<%= telegramUrl %>" class="social-link" aria-label="Telegram" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M21 4.5L2.5 11.7c-.8.3-.8 1.5.1 1.8l4.6 1.5 1.7 5.6c.2.7 1.1.9 1.6.4l2.6-2.5 4.7 3.5c.7.5 1.7.1 1.9-.7l3.1-15.1c.2-.9-.7-1.6-1.4-1.3z" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M8.5 14.5l9-7.5-7 8.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      <% } %>
    </div>
  <% } %>

  <p class="built-by">Built by <a href="https://mdjforge.com" target="_blank" rel="noopener">MDJ FORGE</a></p>
</footer>
