<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', {
    pageTitle: 'Something went wrong — ' + communityName,
    canonicalPath: '/',
    noIndex: true
  }) %>
</head>
<body>
  <div class="wrap center">
    <h1 class="display" style="font-size: 28px;">Something went wrong</h1>
    <p class="lede" style="margin: 0 auto;"><%= message %></p>
    <a href="/" class="btn btn-ghost" style="display:inline-flex; width:auto; padding: 10px 20px;">Back to home</a>
  </div>
</body>
</html>
